{
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "e2e": "playwright test --config playwright.config.ts",
    "e2e:portal": "PLAYWRIGHT_ARTIFACT_SUFFIX=portal playwright test --config playwright.config.ts --project=portal",
    "e2e:admin": "PLAYWRIGHT_ARTIFACT_SUFFIX=admin playwright test --config playwright.config.ts --project=admin",
    "e2e:report": "playwright show-report playwright-report",
    "e2e:report:portal": "playwright show-report playwright-report/portal",
    "e2e:report:admin": "playwright show-report playwright-report/admin",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "cli": "bun apps/cli/src/index.ts"
  },
  "devDependencies": {
    "@inquirer/prompts": "^8.4.0",
    "@playwright/test": "^1.59.1",
    "@types/bun": "^1.3.11",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^8.57.1",
    "prettier": "^3.8.1",
    "turbo": "^2.9.4",
    "vitest": "^4.1.3"
  },
  "name": "stealthy-chicken",
  "packageManager": "bun@1.2.17",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
